# Variables NO secretas para:
# docker compose --env-file .env.prod -f docker-compose.prod.yml ...
RRHH_IMAGE=gestion-rrhh:local
RRHH_WEB_IMAGE=gestion-rrhh-web:local
RRHH_POSTGRES_IMAGE=gestion-rrhh-postgres:local
PROXY_NETWORK=reverse-proxy
ALLOWED_HOSTS=rrhh.example.com
CSRF_TRUSTED_ORIGINS=https://rrhh.example.com
# Vacío si frontend y API comparten origen.
CORS_ALLOWED_ORIGINS=
POSTGRES_DB=rrhh
# Owner usado únicamente por PostgreSQL y el job operativo migrate.
# En una base existente debe ser el owner actual; no renombrarlo por suposición.
POSTGRES_ADMIN_USER=rrhh_owner
# Rol sin ownership ni atributos privilegiados usado por Gunicorn.
POSTGRES_APP_USER=rrhh_runtime
# Volúmenes externos con identidad explícita: nunca dependen del nombre del proyecto.
# En una instalación existente, usar los nombres exactos que ya contienen los datos.
RRHH_POSTGRES_VOLUME=rrhh-prod-postgres
RRHH_MEDIA_VOLUME=rrhh-prod-media
# Duración máxima de una sesión activa (la cookie también vence al cerrar el navegador).
SESSION_COOKIE_AGE=28800

# Directorio padre 0700 y archivos 0444 distintos, fuera del repositorio. Los archivos
# deben ser legibles por los UID no-root a los que Compose los monta; el directorio padre
# impide que otros usuarios del host los recorran.
RRHH_SECRET_KEY_FILE=/opt/nexoflow/secrets/rrhh_django_secret_key
RRHH_DB_ADMIN_PASSWORD_FILE=/opt/nexoflow/secrets/rrhh_postgres_admin_password
RRHH_DB_APP_PASSWORD_FILE=/opt/nexoflow/secrets/rrhh_postgres_app_password
